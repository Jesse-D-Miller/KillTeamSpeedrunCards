{
  "name": "killteamspeedruncards",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/wsServer.js",
    "dev:server:watch": "nodemon --watch server --ext js --exec \"node server/wsServer.js\"",
    "dev:all": "concurrently -k -n web,ws -c cyan,green \"npm run dev\" \"npm run dev:server:watch\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "nodemon": "^3.1.4",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
